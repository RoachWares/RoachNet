<Window
    x:Class="RoachNet.Setup.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="RoachNet Setup">
    <Grid Background="#080A0B">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="36,28,36,0" Spacing="14">
            <TextBlock Text="ROACHNET SETUP"
                       FontSize="12"
                       FontWeight="SemiBold"
                       LetterSpacing="180"
                       Foreground="#18F577" />
            <TextBlock Text="Set up RoachNet."
                       FontSize="34"
                       FontWeight="SemiBold"
                       Foreground="#F4F7F8" />
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Border Background="#1A1F21" BorderBrush="#2AF57A" BorderThickness="1" CornerRadius="999" Padding="12,8">
                    <TextBlock Text="1 Welcome" Foreground="#F4F7F8" />
                </Border>
                <Border Background="#141719" BorderBrush="#2A2F32" BorderThickness="1" CornerRadius="999" Padding="12,8">
                    <TextBlock Text="2 Machine" Foreground="#93A0A5" />
                </Border>
                <Border Background="#141719" BorderBrush="#2A2F32" BorderThickness="1" CornerRadius="999" Padding="12,8">
                    <TextBlock Text="3 Runtime" Foreground="#93A0A5" />
                </Border>
                <Border Background="#141719" BorderBrush="#2A2F32" BorderThickness="1" CornerRadius="999" Padding="12,8">
                    <TextBlock Text="4 RoachClaw" Foreground="#93A0A5" />
                </Border>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1"
                Margin="36,28,36,28"
                Padding="28"
                Background="#121618"
                BorderBrush="#22282B"
                BorderThickness="1"
                CornerRadius="28">
            <Grid ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="250" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="18">
                    <TextBlock Text="One guided install."
                               FontSize="15"
                               Foreground="#93A0A5" />
                    <UniformGrid Columns="3">
                        <Border Margin="0,0,12,0" Padding="16" Background="#171C1E" CornerRadius="20">
                            <StackPanel Spacing="8">
                                <TextBlock Text="INSTALL ROOT" FontSize="11" Foreground="#93A0A5" />
                                <TextBlock Text="RoachNet/" TextWrapping="Wrap" FontSize="16" FontWeight="SemiBold" Foreground="#F4F7F8" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,12,0" Padding="16" Background="#171C1E" CornerRadius="20">
                            <StackPanel Spacing="8">
                                <TextBlock Text="RUNTIME" FontSize="11" Foreground="#93A0A5" />
                                <TextBlock Text="Managed" FontSize="16" FontWeight="SemiBold" Foreground="#F4F7F8" />
                            </StackPanel>
                        </Border>
                        <Border Padding="16" Background="#171C1E" CornerRadius="20">
                            <StackPanel Spacing="8">
                                <TextBlock Text="ROACHCLAW" FontSize="11" Foreground="#93A0A5" />
                                <TextBlock Text="qwen3.5:latest" FontSize="16" FontWeight="SemiBold" Foreground="#F4F7F8" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </StackPanel>

                <Border Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="200"
                        Height="200"
                        CornerRadius="100"
                        BorderBrush="#2AF57A"
                        BorderThickness="1">
                    <Grid>
                        <TextBlock Text="RN"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="#F4F7F8" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="36,0,36,28">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1"
                    Content="Continue"
                    Padding="18,10"
                    Background="#15191B"
                    BorderBrush="#2AF57A"
                    BorderThickness="1.5"
                    Foreground="#F4F7F8" />
        </Grid>
    </Grid>
</Window>
