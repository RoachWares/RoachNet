<Window
    x:Class="RoachNet.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="RoachNet">
    <Grid Background="#080A0B">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="290" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Background="#101417" BorderBrush="#22282B" BorderThickness="0,0,1,0">
            <StackPanel Margin="24" Spacing="18">
                <TextBlock Text="ROACHNET" FontSize="12" FontWeight="SemiBold" LetterSpacing="180" Foreground="#18F577" />
                <TextBlock Text="Native workspace" FontSize="28" FontWeight="SemiBold" Foreground="#F4F7F8" />

                <StackPanel Spacing="8">
                    <Button Content="Overview" HorizontalAlignment="Stretch" />
                    <Button Content="RoachClaw" HorizontalAlignment="Stretch" />
                    <Button Content="Knowledge" HorizontalAlignment="Stretch" />
                    <Button Content="Runtime" HorizontalAlignment="Stretch" />
                </StackPanel>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="28" Spacing="18">
                <Border Padding="24" Background="#121618" BorderBrush="#22282B" BorderThickness="1" CornerRadius="28">
                    <StackPanel Spacing="14">
                        <TextBlock Text="OVERVIEW" FontSize="12" FontWeight="SemiBold" LetterSpacing="180" Foreground="#18F577" />
                        <TextBlock Text="One local command center." FontSize="38" FontWeight="SemiBold" Foreground="#F4F7F8" />
                        <TextBlock Text="RoachClaw, runtime, and knowledge in one native workspace." FontSize="16" Foreground="#93A0A5" />
                    </StackPanel>
                </Border>

                <UniformGrid Columns="3">
                    <Border Margin="0,0,12,0" Padding="16" Background="#171C1E" CornerRadius="22">
                        <StackPanel Spacing="8">
                            <TextBlock Text="MODEL" FontSize="11" Foreground="#93A0A5" />
                            <TextBlock Text="qwen2.5-coder:7b" FontSize="18" FontWeight="SemiBold" Foreground="#F4F7F8" />
                        </StackPanel>
                    </Border>
                    <Border Margin="0,0,12,0" Padding="16" Background="#171C1E" CornerRadius="22">
                        <StackPanel Spacing="8">
                            <TextBlock Text="RUNTIME" FontSize="11" Foreground="#93A0A5" />
                            <TextBlock Text="Healthy" FontSize="18" FontWeight="SemiBold" Foreground="#F4F7F8" />
                        </StackPanel>
                    </Border>
                    <Border Padding="16" Background="#171C1E" CornerRadius="22">
                        <StackPanel Spacing="8">
                            <TextBlock Text="MODE" FontSize="11" Foreground="#93A0A5" />
                            <TextBlock Text="Native" FontSize="18" FontWeight="SemiBold" Foreground="#F4F7F8" />
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
