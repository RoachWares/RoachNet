{
  "extends": "@adonisjs/tsconfig/tsconfig.app.json",
  "compilerOptions": {
    "rootDir": "./",
    "outDir": "./build",
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "strictPropertyInitialization": false,
    "skipLibCheck": true
  },
  "exclude": [
    "./inertia/**/*",
    "./public/**/*",
    "./storage/**/*",
    "node_modules",
    "node_modules_node25_partial_20260327",
    "build"
  ]
}
